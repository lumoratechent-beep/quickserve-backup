CREATE TABLE public.users (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  username text NOT NULL UNIQUE,
  password text NOT NULL,
  role text NOT NULL CHECK (role = ANY (ARRAY['CUSTOMER'::text, 'VENDOR'::text, 'ADMIN'::text, 'CASHIER'::text, 'KITCHEN'::text, 'ORDER_TAKER'::text, 'MANAGER'::text, 'HR'::text])),
  restaurant_id uuid,
  is_active boolean DEFAULT true,
  email text,
  phone text,
  created_at timestamp with time zone DEFAULT now(),
  kitchen_categories jsonb,
  access_permissions jsonb DEFAULT '{}'::jsonb,
  CONSTRAINT users_pkey PRIMARY KEY (id),
  CONSTRAINT fk_users_restaurant FOREIGN KEY (restaurant_id) REFERENCES public.restaurants(id)
);
CREATE TABLE public.areas (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  name text NOT NULL,
  city text NOT NULL,
  state text NOT NULL,
  code text NOT NULL UNIQUE,
  is_active boolean DEFAULT true,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT areas_pkey PRIMARY KEY (id)
);
CREATE TABLE public.restaurants (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  name text NOT NULL,
  logo text,
  vendor_id uuid,
  location_name text,
  is_online boolean DEFAULT true,
  settings jsonb DEFAULT '{}'::jsonb,
  created_at timestamp with time zone DEFAULT now(),
  categories jsonb DEFAULT '[]'::jsonb,
  modifiers jsonb DEFAULT '[]'::jsonb,
  slug text UNIQUE,
  kitchen_divisions jsonb,
  kitchen_enabled boolean DEFAULT false,
  add_on_items jsonb DEFAULT '[]'::jsonb,
  CONSTRAINT restaurants_pkey PRIMARY KEY (id),
  CONSTRAINT restaurants_location_name_fkey FOREIGN KEY (location_name) REFERENCES public.areas(name),
  CONSTRAINT restaurants_vendor_id_fkey FOREIGN KEY (vendor_id) REFERENCES public.users(id)
);
CREATE TABLE public.menu_items (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  restaurant_id uuid,
  name text NOT NULL,
  description text,
  price numeric NOT NULL,
  image text,
  category text NOT NULL,
  is_archived boolean DEFAULT false,
  sizes jsonb DEFAULT '[]'::jsonb,
  temp_options jsonb DEFAULT '{"hot": 0, "cold": 0, "enabled": false}'::jsonb,
  other_variants jsonb DEFAULT '{"name": "", "enabled": false, "options": []}'::jsonb,
  created_at timestamp with time zone DEFAULT now(),
  add_ons jsonb DEFAULT '[]'::jsonb,
  CONSTRAINT menu_items_pkey PRIMARY KEY (id),
  CONSTRAINT menu_items_restaurant_id_fkey FOREIGN KEY (restaurant_id) REFERENCES public.restaurants(id)
);
CREATE TABLE public.orders (
  id text NOT NULL,
  items jsonb NOT NULL,
  total numeric NOT NULL,
  status text NOT NULL CHECK (status = ANY (ARRAY['PENDING'::text, 'ONGOING'::text, 'SERVED'::text, 'COMPLETED'::text, 'CANCELLED'::text])),
  timestamp bigint NOT NULL,
  customer_id text NOT NULL,
  restaurant_id uuid,
  table_number text,
  location_name text,
  remark text,
  rejection_reason text,
  rejection_note text,
  created_at timestamp with time zone DEFAULT now(),
  payment_method text,
  cashier_name text,
  amount_received numeric,
  change_amount numeric,
  order_source text,
  dining_type text,
  CONSTRAINT orders_pkey PRIMARY KEY (id),
  CONSTRAINT orders_restaurant_id_fkey FOREIGN KEY (restaurant_id) REFERENCES public.restaurants(id),
  CONSTRAINT orders_location_name_fkey FOREIGN KEY (location_name) REFERENCES public.areas(name)
);
CREATE TABLE public.subscriptions (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  restaurant_id uuid NOT NULL UNIQUE,
  plan_id text NOT NULL CHECK (plan_id = ANY (ARRAY['basic'::text, 'pro'::text, 'pro_plus'::text])),
  status text NOT NULL DEFAULT 'pending_payment'::text CHECK (status = ANY (ARRAY['pending_payment'::text, 'trialing'::text, 'active'::text, 'past_due'::text, 'canceled'::text, 'unpaid'::text])),
  stripe_customer_id text,
  stripe_subscription_id text,
  trial_start timestamp with time zone NOT NULL DEFAULT now(),
  trial_end timestamp with time zone NOT NULL DEFAULT (now() + '30 days'::interval),
  current_period_start timestamp with time zone,
  current_period_end timestamp with time zone,
  cancel_at_period_end boolean DEFAULT false,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  billing_interval text DEFAULT 'monthly'::text CHECK (billing_interval = ANY (ARRAY['monthly'::text, 'annual'::text])),
  pending_plan_id text CHECK (pending_plan_id = ANY (ARRAY['basic'::text, 'pro'::text, 'pro_plus'::text])),
  pending_billing_interval text CHECK (pending_billing_interval = ANY (ARRAY['monthly'::text, 'annual'::text])),
  pending_change_effective_at timestamp with time zone,
  duitnow_enabled boolean DEFAULT false,
  access_locked boolean NOT NULL DEFAULT false,
  access_lock_at timestamp with time zone,
  access_locked_at timestamp with time zone,
  CONSTRAINT subscriptions_pkey PRIMARY KEY (id),
  CONSTRAINT subscriptions_restaurant_id_fkey FOREIGN KEY (restaurant_id) REFERENCES public.restaurants(id)
);
